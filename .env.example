# YouTube API Configuration
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_USERNAME=@MoneyPurse
# Optional: Use channel ID directly if username lookup doesn't work
# YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxx

# NotebookLM Configuration
NOTEBOOKLM_NOTEBOOK_ID=your_notebook_id_here

# Email Configuration (Gmail example)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_RECIPIENT=recipient@example.com

# NotebookLM Prompt
NOTEBOOKLM_PROMPT=Analyze this video and provide key insights, takeaways, and actionable recommendations.

# State File Path
STATE_FILE_PATH=.youtube_notebooklm/processed_videos.json
